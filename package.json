{
  "name": "jspdf-markdown",
  "version": "1.0.1",
  "description": "Render Markdown into jsPDF with full inline formatting, styled tables (incl. merged cells), and a precise positional layout API (columns, headers/footers, measurement).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "jspdf",
    "markdown",
    "pdf",
    "autotable",
    "table-styling",
    "layout",
    "columns",
    "header-footer",
    "gfm",
    "typescript"
  ],
  "author": "Mark Joseph Solidarios",
  "license": "MIT",
  "dependencies": {
    "marked": "^12.0.0"
  },
  "peerDependencies": {
    "jspdf": ">=2.0.0",
    "jspdf-autotable": ">=3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^29.7.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^jspdf$": "<rootDir>/node_modules/jspdf/dist/jspdf.node.min.js"
    }
  }
}
